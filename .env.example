# Copy this file to `.env` and fill in your API keys.
#   cp .env.example .env        (macOS / Linux)
#   copy .env.example .env      (Windows)
#
# Never commit `.env` — it is listed in .gitignore.

# OpenAI — slide plans, speaker notes, and presentation content
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ElevenLabs — text-to-speech for each slide's speaker notes
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_your-elevenlabs-api-key-here

# ElevenLabs voice ID (from Voice Library or your voices page)
# https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=your-voice-id-here
